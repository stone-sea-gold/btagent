# LLM Provider: "anthropic", "openai", "deepseek", "ollama", "custom"
#
# Protocol auto-detection:
#   - URL contains "/anthropic" → uses Anthropic SDK (ChatAnthropic)
#   - Otherwise → uses OpenAI SDK (ChatOpenAI)
#   - "ollama" → always uses ChatOllama
#
# So any provider with OpenAI or Anthropic-compatible API works.

LLM_PROVIDER=deepseek

# Anthropic (Claude) — official API
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OpenAI — official API
OPENAI_API_KEY=sk-xxx
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=

# DeepSeek (auto-detects protocol from URL)
DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_MODEL=deepseek-chat
# Anthropic-compatible: https://api.deepseek.com/anthropic
# OpenAI-compatible:    https://api.deepseek.com
DEEPSEEK_BASE_URL=https://api.deepseek.com/anthropic

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b

# Custom provider (for any OpenAI/Anthropic-compatible API)
LLM_API_KEY=
LLM_MODEL=
LLM_BASE_URL=

# Shared LLM settings
LLM_TIMEOUT=60.0
LLM_MAX_RETRIES=3

# Qlib
QLIB_DATA_PATH=~/.qlib/qlib_data/cn_data

# Database
SQLITE_DB_PATH=./data/aifund.db

# ChromaDB
CHROMA_PERSIST_DIR=./chroma_db

# Logging
LOG_LEVEL=INFO
